{
    "manifest_version": 3,
    "name": "Scheme-JS Debugger",
    "version": "0.3.0",
    "description": "Standalone debugger window for debugging scheme-js programs.",
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["activate_debug.js"],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["content_script.js"],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "debugger",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "Open Scheme-JS Debugger",
        "default_icon": {
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
