{
    "manifest_version": 3,
    "name": "Scheme-JS Debugger",
    "version": "0.2.0",
    "description": "Top-level Scheme-JS DevTools panel for debugging scheme-js programs.",
    "devtools_page": "devtools.html",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "debugger"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
